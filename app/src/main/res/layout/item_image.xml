<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <ImageView
        android:id="@+id/imageView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <ImageView
        android:id="@+id/starOverlay"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_margin="6dp"
        android:visibility="gone"
        android:src="@drawable/baseline_star_24"
        android:tint="#FFFFFF"
        android:background="@drawable/star_circle_bg"
        android:padding="2dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Blue circle background -->
    <View
        android:id="@+id/selectionCircle"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:layout_margin="6dp"
        android:visibility="gone"
        android:background="@drawable/selection_circle"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Check mark -->
    <ImageView
        android:id="@+id/checkMark"
        android:layout_width="14dp"
        android:layout_height="14dp"
        android:visibility="gone"
        android:src="@drawable/ic_check_white"
        app:layout_constraintBottom_toBottomOf="@id/selectionCircle"
        app:layout_constraintTop_toTopOf="@id/selectionCircle"
        app:layout_constraintStart_toStartOf="@id/selectionCircle"
        app:layout_constraintEnd_toEndOf="@id/selectionCircle"/>

</androidx.constraintlayout.widget.ConstraintLayout>