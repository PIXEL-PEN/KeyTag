<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:background="#34495E"
        android:titleTextColor="@android:color/white"
        app:titleTextAppearance="@style/ToolbarTitle"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="KeyTag"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#FFC107"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Version 0.1 — Open Source"
                android:textSize="13sp"
                android:textColor="#BBBBBB"
                android:layout_marginBottom="24dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="What is KeyTag?"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#CCCCCC"
                android:lineSpacingMultiplier="1.5"
                android:layout_marginBottom="24dp"
                android:text="KeyTag is a lightweight Digital Asset Manager (DAM) for Android. It works alongside your native gallery app — adding keywords, star ratings and metadata to your photos and videos without replacing the gallery experience you already use."/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Basic Workflow"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#CCCCCC"
                android:lineSpacingMultiplier="1.5"
                android:layout_marginBottom="24dp"
                android:text="1. Organise photos into albums using your native gallery app.\n\n2. Open KeyTag to browse those same albums.\n\n3. Select images and tap TAG to assign keywords and star ratings.\n\n4. Use Search to find images by keyword or star rating across all albums.\n\n5. Share images from your gallery directly to KeyTag to tag them on the spot."/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ShortList"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#CCCCCC"
                android:lineSpacingMultiplier="1.5"
                android:layout_marginBottom="24dp"
                android:text="ShortList is a special folder in your Pictures directory. Move images there from your native gallery as a first-pass selection. Open ShortList in KeyTag to tag and rate them, then move them to their final album."/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Star Ratings"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#CCCCCC"
                android:lineSpacingMultiplier="1.5"
                android:layout_marginBottom="24dp"
                android:text="Tap the stars in the top bar while viewing an image to rate it 1–3 stars. Use the TAG dialog to batch-rate selected images. Search by star rating from the main screen."/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="EXIF Panel"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#CCCCCC"
                android:lineSpacingMultiplier="1.5"
                android:layout_marginBottom="24dp"
                android:text="Swipe left or tap the EXIF button while viewing an image to see camera metadata — date, device, lens specs, image dimensions and assigned keywords."/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Open Source"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#CCCCCC"
                android:lineSpacingMultiplier="1.5"
                android:layout_marginBottom="8dp"
                android:text="KeyTag is a free, open source hobby project. Contributions and feedback welcome."/>

        </LinearLayout>
    </ScrollView>

</LinearLayout>