<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:background="#34495E"
        android:titleTextColor="@android:color/white"
        app:titleTextAppearance="@style/ToolbarTitle"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="KeyTag"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#FFC107"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Version 0.1 — Open Source"
                android:textSize="13sp"
                android:textColor="#BBBBBB"
                android:layout_marginBottom="24dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="The feature every gallery app is missing."
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#CCCCCC"
                android:lineSpacingMultiplier="1.5"
                android:layout_marginBottom="24dp"
                android:text="Every Android gallery app lets you organise photos into albums. None of them let you keyword tag a batch of images. KeyTag fills that gap — adding keywords, star ratings and metadata on top of whatever gallery app you already use, without replacing it."/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="1. Keywording"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFC107"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#CCCCCC"
                android:lineSpacingMultiplier="1.5"
                android:layout_marginBottom="24dp"
                android:text="Select any images in your native gallery. Tap Share → KeyTag. A batch tag dialog opens immediately. Type a keyword, tap Apply. Done.\n\nKeywords are stored locally for instant search and written as XMP sidecar files alongside your images. Move an image to another device or open it in Lightroom or Capture One — the keywords are already there. Tag once, search anywhere."/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="2. Categorization"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFC107"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#CCCCCC"
                android:lineSpacingMultiplier="1.5"
                android:layout_marginBottom="24dp"
                android:text="Albums you create in your native gallery appear in KeyTag automatically. No setup, no import.\n\nShortList is a proxy folder for your native gallery Favorites. Keep using the heart/favorite button in your gallery as you always have — something catches your eye, favorite it. Then move those favorites into ShortList. KeyTag picks it up automatically at the top of the album grid. No decisions required at this stage. Keyword, star and categorize later — or not at all. It is the most frictionless first-pass sorting available.\n\nFrom ShortList you can batch select and keyword tag, then move images to their final album in the native gallery when you are ready."/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="3. Starring"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFC107"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#CCCCCC"
                android:lineSpacingMultiplier="1.5"
                android:layout_marginBottom="24dp"
                android:text="Star images 1–3 from the viewer or in batch via the TAG dialog. Search by star rating across your entire library. Useful for filtering your best shots without browsing album by album."/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Videos"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#CCCCCC"
                android:lineSpacingMultiplier="1.5"
                android:layout_marginBottom="24dp"
                android:text="KeyTag includes a dedicated Videos-fin folder for curated video clips. Create a folder called Videos-fin in your Pictures directory and move your final edited videos there using your native gallery or a file manager. KeyTag displays them in their own grid with thumbnails, duration labels and filenames. Tap to play in your native video player. Long press to keyword tag and star rate. Tagged videos appear alongside images in keyword and star search results."/>


            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Search"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#CCCCCC"
                android:lineSpacingMultiplier="1.5"
                android:layout_marginBottom="24dp"
                android:text="Global keyword and star search covers your entire library across all albums in one query. Accessible from the main screen and from within any album."/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="EXIF Panel"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#CCCCCC"
                android:lineSpacingMultiplier="1.5"
                android:layout_marginBottom="24dp"
                android:text="Swipe left while viewing an image to see camera metadata — date, device, lens specs, image dimensions and assigned keywords."/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Open Source"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="8dp"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Privacy"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#CCCCCC"
                android:lineSpacingMultiplier="1.5"
                android:layout_marginBottom="24dp"
                android:text="KeyTag is fully offline. No accounts, no cloud sync, no analytics, no tracking of any kind. All metadata is stored locally on your device in a private database. Nothing leaves your device unless you explicitly share or export a file yourself."/>


            <TextView
                android:id="@+id/feedbackLink"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#64B5F6"
                android:lineSpacingMultiplier="1.5"
                android:layout_marginBottom="8dp"
                android:text="KeyTag is a free, open source project. Contributions and feedback welcome.&#10;&#10;Copyright 2026  TST (PIXEL-PEN)&#10;Licensed under GPL v3&#10;&#10;Feedback and discussions:&#10;github.com/PIXEL-PEN/KeyTag/discussions&#10;&#10;Source code:&#10;github.com/PIXEL-PEN/KeyTag"/>        </LinearLayout>
    </ScrollView>

</LinearLayout>